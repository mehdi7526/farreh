{
  "name": "farreh-gallery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names api,ui --prefix-colors blue,green \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:ui": "vite --host 0.0.0.0 --strictPort",
    "dev:api": ".venv/bin/python backend/manage.py runserver 127.0.0.1:8000",
    "migrate:api": ".venv/bin/python backend/manage.py migrate",
    "test:api": ".venv/bin/python backend/manage.py test",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.3.5"
  }
}
